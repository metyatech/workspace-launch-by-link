{
    "name": "workspace-launch-by-link",
    "displayName": "Workspace Launch by Link",
    "description": "Webリンクからワークスペースを起動し、内容をサーバーとリアルタイム同期する VS Code 拡張機能",
    "publisher": "Kodai-Yamamoto-SIW",
    "version": "0.0.1",
    "type": "module",
    "engines": {
        "vscode": ">=1.87.0"
    },
    "categories": [
        "Education"
    ],
    "activationEvents": [
        "onUri",
        "workspaceContains:.vscode/workspace-launch-by-link.json"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "workspaceLaunchByLink.showStatus",
                "title": "Workspace Launch by Link: Show Status"
            }
        ],
        "configuration": {
            "type": "object",
            "title": "Workspace Launch by Link",
            "properties": {
                "workspaceLaunchByLink.telemetry": {
                    "type": "boolean",
                    "default": false,
                    "description": "匿名メトリクス送信（本プロジェクトでは無効のまま推奨）"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "package": "vsce package",
        "lint": "eslint src/**/*.ts",
        "format": "prettier --write \"src/**/*.ts\"",
        "format:check": "prettier --check \"src/**/*.ts\"",
        "test": "vitest run",
        "verify": "npm run lint && npm run format:check && npm run compile && npm run test",
        "mock-server": "node tools/mock-server.js"
    },
    "devDependencies": {
        "@eslint/js": "^9.17.0",
        "@types/mocha": "^10.0.10",
        "@types/node": "^22.10.2",
        "@types/vscode": "^1.104.0",
        "@typescript-eslint/eslint-plugin": "^8.18.0",
        "@typescript-eslint/parser": "^8.18.0",
        "@vitest/coverage-v8": "^3.0.7",
        "@vscode/vsce": "^3.6.2",
        "eslint": "^9.17.0",
        "eslint-config-prettier": "^10.0.1",
        "eslint-plugin-prettier": "^5.2.1",
        "mocha": "^11.1.0",
        "prettier": "^3.4.2",
        "ts-expect": "^1.3.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.7.2",
        "vitest": "^3.0.7"
    },
    "dependencies": {
        "cross-fetch": "^4.1.0",
        "isbinaryfile": "^5.0.6"
    },
    "overrides": {
        "qs": ">=6.14.2",
        "minimatch": ">=10.2.1",
        "glob": ">=11.1.0",
        "@isaacs/brace-expansion": ">=5.0.1",
        "undici": ">=7.18.2"
    }
}
